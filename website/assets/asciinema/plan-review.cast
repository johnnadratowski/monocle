[0.489, "o", "\u001b[3;54H\u001b[7m1   # `:jump` Command Implementation \u001b[94b\u001b[m\u001b[4;54H\u001b[90m2   \u001b[m\u001b[118X\n\u001b[4D\u001b[90m3   \u001b[34;1mOverview\u001b[m\u001b[117X\u001b[6;54H\u001b[90m4   \u001b[mAdd a \u001b[33m:jump <line>\u001b[m command (alias \u001b[33m:j\u001b[m) that scrolls the\u001b[64X\u001b[7;54H\u001b[90m5   \u001b[mdiff view to a specific source file line number. Lets\u001b[64X\u001b[8;54H\u001b[90m6   \u001b[mreviewers navigate directly to a line they care about.\u001b[73X\u001b[9;54H\u001b[90m7   \u001b[m\u001b[124X\n\u001b[4D\u001b[90m8   \u001b[34;1mApproach\u001b[m\u001b[119X\u001b[11;54H\u001b[90m9   \u001b[35mвҖў\u001b[m Parse \u001b[33m:jump N\u001b[m and \u001b[33m:j N\u001b[m in command mode dispatcher\u001b[16X\u001b[12;54H\u001b[90m10  \u001b[35mвҖў\u001b[m Resolve source line вҶ’ diff view row, accounting for hunk\u001b[69X\u001b[13;54H\u001b[90m11  \u001b[m  boundaries, context lines, and collapsed sections\u001b[63X\u001b[14;54H\u001b[90m12  \u001b[35mвҖў\u001b[m Center the viewport on the target row and scroll\u001b[15;54H\u001b[90m13  \u001b[35mвҖў\u001b[m Show error toast if line is out of range or not in diff\u001b[57X\u001b[16;54H\u001b[90m14  \u001b[35mвҖў\u001b[m Validate input: reject negative numbers, zero, non-numeric\u001b[63X\u001b[17;54H\u001b[90m15  \u001b[m\u001b[113X\n\u001b[4D\u001b[90m16  \u001b[34;1mFiles to Create\u001b[m\u001b[1"]
