[0.000, "o", "ster Monocle with your agent:\u001b[m\u001b[73X\u001b[73C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[10;63H\u001b[2m  \u001b[33mmonocle register\u001b[m\u001b[104X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[12;63H\u001b[2mOr manually install via your agent's plugin/extension system:\u001b[m\u001b[61X\u001b[61C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[14;63H\u001b[2mClaude Code:\u001b[m\u001b[110X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[15;63H\u001b[2m  \u001b[33m/plugin marketplace add josephschmitt/monocle\u001b[m\u001b[75X\u001b[75C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[16;63H\u001b[2m  \u001b[33m/plugin install monocle@monocle\u001b[m\u001b[89X\u001b[89C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[18;63H\u001b[2mGemini CLI:\u001b[m\u001b[111X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[19;63H\u001b[2m  \u001b[33mgemini extensions install josephschmitt/monocle\u001b[m\u001b[73X\u001b[73C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[21;63H\u001b[2mDiffs appear here as your agent works.\u001b[m\u001b[84X\u001b[84C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[23;63H\u001b[2mв”Җв”Җв”Җв”Җв”Җ\u001b[m\u001b[117X\u001b[185`\u001b[34"]
[0.000, "o", "mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[25;63H\u001b[36mReview\u001b[m\u001b[116X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[26;63H\u001b[2mpress \u001b[33;22mc  \u001b[39;2m to comment on a line\u001b[m\u001b[92X\u001b[92C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[27;63H\u001b[2mpress \u001b[33;22mC  \u001b[39;2m to comment on a file\u001b[m\u001b[92X\u001b[92C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[28;63H\u001b[2mpress \u001b[33;22mS  \u001b[39;2m to submit your review\u001b[m\u001b[91X\u001b[91C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[30;63H\u001b[36mFeedback\u001b[m\u001b[114X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[31;63H\u001b[2mSubmit sends your review to the feedback queue.\u001b[m\u001b[75X\u001b[75C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[32;63H\u001b[2mThe agent picks it up via the \u001b[33;22m/get-feedback\u001b[39;2m skill.\u001b[m\u001b[72X\u001b[72C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[34;63H\u001b[2mpress \u001b[33;22m?  \u001b[39;2m for keybinding help\u001b[m\u001b[93X\u001b[93C\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[61X\u001b[35;63H\u001b[2mpress \u001b[33;22mq  \u001b[39;2m to quit\u001b[m\u001b[105X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[34mв”Ӯ\u001b[m\u001b[183X\u001b[185`\u001b[34mв”Ӯ\u001b[m\r\n\u001b[3"]
