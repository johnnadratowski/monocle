[0.000, "o", "ers the diff viewport on the given source file line number.\u001b[39m \u001b[11b\u001b[m\u001b[25;32H\u001b[20X\u001b[25;52H\u001b[90mв”Ӯ\u001b[34mв”Ӯ\u001b[90;48;2;19;42;19m \u001b[6b19 \u001b[38;2;117;113;94m// Returns an error string if the line cannot be found, or empty string on success.\u001b[39m \u001b[7b\u001b[m\u001b[26;32H\u001b[20X\u001b[26;52H\u001b[90mв”Ӯ\u001b[34mв”Ӯ\u001b[39;7m \u001b[6b20 func scrollToLine(dv *diffViewModel, lineNum int) string { \u001b[32b\u001b[m\u001b[27;32H\u001b[20X\u001b[27;52H\u001b[90mв”Ӯ\u001b[34mв”Ӯ\u001b[90;48;2;19;42;19m \u001b[6b21 \u001b[38;2;248;248;242m    \u001b[38;2;166;226;46mrow\u001b[38;2;248;248;242m \u001b[38;2;249;38;114m:=\u001b[38;2;248;248;242m \u001b[38;2;166;226;46mresolveLineToRow\u001b[38;2;248;248;242m(\u001b[38;2;166;226;46mdv\u001b[38;2;248;248;242m.\u001b[38;2;166;226;46mlines\u001b[38;2;248;248;242m, \u001b[38;2;166;226;46mlineNum\u001b[38;2;248;248;242m)\u001b[39m\u001b[45X\u001b[m\u001b[28;32H\u001b[20X\u001b[28;52H\u001b[90mв”Ӯ\u001b[34mв”Ӯ\u001b[90;48;2;19;42;19m \u001b[6b22 \u001b[38;2;248;248;242m    \u001b[38;2;102;217;239mif\u001b[38;2;248;248;242m \u001b[38;2;166;226;46mrow\u001b[38;2;248;248;242m < \u001b[38;2;174;129;255m0\u001b[38;2;248;248;242m {\u001b[39m\u001b[75X\u001b[m"]
